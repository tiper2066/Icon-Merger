# Supabase Transaction Pooler URL for application runtime.
# Supabase Dashboard > Project Settings > Database > Connection string > Transaction pooler
DATABASE_URL="postgresql://postgres.projectref:YOUR_DB_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Direct Connection URL for Prisma migrations and schema commands.
# Supabase Dashboard > Project Settings > Database > Connection string > Direct connection
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.projectref.supabase.co:5432/postgres"
